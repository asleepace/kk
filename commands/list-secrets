#!/bin/bash
# Usage: kk list-secrets

DESCRIPTION="List all secrets in .kk namespace stored in macOS Keychain."
source "$HOME/.kk/lib/common"
#kk_trap_errors

set +e
RESULTS=$(security dump-keychain 2>/dev/null \
  | awk -F'"' '/svce/ { svc=$4 } /acct/ && svc { print svc; svc="" }' \
  | grep '^kk\.' \
  | sed 's/^kk\.//' \
  | sort)
set -e

if [ -z "$RESULTS" ]; then
  echo "no secrets found."
else
  echo "$RESULTS"
fi