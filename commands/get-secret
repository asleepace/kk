#!/bin/bash
# Usage: kk get-secret <name>

DESCRIPTION="Retrieve a secret from macOS Keychain."
source "$HOME/.kk/lib/common"
kk_trap_errors

if [ -z "$1" ]; then
  kk_die "Usage: kk get-secret <name>"
fi

VALUE=$(security find-generic-password -a "$USER" -s "kk.$1" -w 2>/dev/null)
[ -z "$VALUE" ] && kk_die "Secret not found: $1"
echo "$VALUE"