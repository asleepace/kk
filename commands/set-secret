#!/bin/bash
# Usage: kk set-secret <name> <value>

DESCRIPTION="Store a secret in macOS Keychain."
source "$HOME/.kk/lib/common"
kk_trap_errors

if [ -z "${1:-}" ] || [ -z "${2:-}" ]; then
  kk_die "Usage: kk set-secret <name> <value>"
fi

set +e
security delete-generic-password -a "$USER" -s "kk.$1" &>/dev/null || true
set -e
security add-generic-password -a "$USER" -s "kk.$1" -w "$2"
echo -e "✓ Stored secret: $GREEN$1$NC"
